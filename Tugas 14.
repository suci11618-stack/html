        </div>
    </div>

    <!-- ============================================= -->
    <!-- KOMPONEN 12: TOAST (Notifikasi Dinamis)       -->
    <!-- ============================================= -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="liveToast" class="toast glass-card border border-info text-white" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header bg-indigo text-white border-bottom border-secondary d-flex justify-between">
                <strong class="me-auto text-glow text-info"><i class="bi bi-lightning-charge-fill"></i> Sistem Diperbarui</strong>
                <small>Baru saja</small>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Tutup"></button>
            </div>
            <div class="toast-body" id="toastMessage">
                Konfigurasi gravitasi berhasil dimutakhirkan!
            </div>
        </div>
    </div>

    <!-- Bootstrap 5 Bundle JS (Includes Popper) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Interactive Canvas & State Simulation Logic -->
    <script>
        // DOM Elements
        const canvas = document.getElementById('gravityCanvas');
        const ctx = canvas.getContext('2d');
        const antiGravitySwitch = document.getElementById('antiGravitySwitch');
        const switchLabel = document.getElementById('switchLabel');
        const particleCountInput = document.getElementById('particleCount');
        const particleCountVal = document.getElementById('particleCountVal');
        const particleSpeedInput = document.getElementById('particleSpeed');
        const powerVal = document.getElementById('powerVal');
        const resetBtn = document.getElementById('resetBtn');
        const stabilityBar = document.getElementById('stabilityBar');
        const tempBar = document.getElementById('tempBar');
        const telemetryLog = document.getElementById('telemetryLog');
        const calibrateBtn = document.getElementById('calibrateBtn');

        // Physics State
        let particles = [];
        let isAntiGravity = false;
        let gravityForce = 0.5; // default gravity pull down
        let maxParticles = parseInt(particleCountInput.value);

        // Resize Canvas dynamically keeping mobile-friendliness in mind
        function resizeCanvas() {
            const containerWidth = canvas.parentElement.clientWidth;
            canvas.width = containerWidth;
            canvas.height = 380; // Fixed aesthetic height
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        // Particle Class
        class Particle {
            constructor(x, y, manual = false) {
                this.x = x || Math.random() * canvas.width;
                this.y = y || Math.random() * canvas.height;
                this.radius = Math.random() * 8 + 4;
                this.color = manual ? '#ea00d9' : `hsl(${Math.random() * 60 + 190}, 100%, 65%)`; // Cyan variations or pink for manual
                this.vx = (Math.random() - 0.5) * 4;
                this.vy = (Math.random() - 0.5) * 4;
                this.bounciness = 0.7;
            }

            update() {
                // Apply Gravity Vector
                if (isAntiGravity) {
                    // Floating upward vector
                    this.vy -= (gravityForce * 0.15);
                } else {
                    // Normal downward gravity vector
                    this.vy += gravityForce;
                }

                this.x += this.vx;
                this.y += this.vy;

                // Collision with Walls
                if (this.x + this.radius > canvas.width) {
                    this.x = canvas.width - this.radius;
                    this.vx *= -this.bounciness;
                } else if (this.x - this.radius < 0) {
                    this.x = this.radius;
                    this.vx *= -this.bounciness;
                }

                // Collision with Ceiling / Floor
                if (this.y + this.radius > canvas.height) {
                    this.y = canvas.height - this.radius;
                    this.vy *= -this.bounciness;
                    // friction
                    this.vx *= 0.98;
                } else if (this.y - this.radius < 0) {
                    this.y = this.radius;
                    this.vy *= -this.bounciness;
                    this.vx *= 0.98;
                }
            }

            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                ctx.fillStyle = this.color;
                ctx.shadowBlur = 10;
                ctx.shadowColor = this.color;
                ctx.fill();
                ctx.closePath();
                ctx.shadowBlur = 0; // reset for performance
            }
        }

        // Initialize Particles
        function initParticles() {
            particles = [];
            for (let i = 0; i < maxParticles; i++) {
                particles.push(new Particle());
            }
        }
        initParticles();

        // Spawn on Canvas Click
        canvas.addEventListener('click', (e) => {
            const rect = canvas.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            particles.push(new Particle(x, y, true));
            if (particles.length > 120) particles.shift(); // Performance guard
            addTelemetryLog("Pengguna memasukkan objek manual pada ruang.", "INJECTION");
        });

        // Animation Loop
        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // Background cosmic matrix effect grid
            ctx.strokeStyle = 'rgba(129, 140, 248, 0.05)';
            ctx.lineWidth = 1;
            const gridSize = 40;
            for(let x = 0; x < canvas.width; x += gridSize) {
                ctx.beginPath();
                ctx.moveTo(x, 0);
                ctx.lineTo(x, canvas.height);
                ctx.stroke();
            }
            for(let y = 0; y < canvas.height; y += gridSize) {
                ctx.beginPath();
                ctx.moveTo(0, y);
                ctx.lineTo(canvas.width, y);
                ctx.stroke();
            }

            // Draw and update particles
            particles.forEach(p => {
                p.update();
                p.draw();
            });

            requestAnimationFrame(animate);
        }
        animate();

        // Controls Event Listeners
        antiGravitySwitch.addEventListener('change', (e) => {
            isAntiGravity = e.target.checked;
            if (isAntiGravity) {
                switchLabel.innerHTML = "ANTI-GRAVITASI AKTIF";
                switchLabel.className = "text-info text-glow ms-2";
                tempBar.style.width = "75%";
                stabilityBar.style.width = "95%";
                addTelemetryLog("Gaya tolak diaktifkan. Reaktor memanas.", "WARP_ENGAGED");
                showToast("Sistem gravitasi dibalikkan secara sukses!");
            } else {
                switchLabel.innerHTML = "GAYA TARIK BUMI";
                switchLabel.className = "text-danger ms-2";
                tempBar.style.width = "42%";
                stabilityBar.style.width = "85%";
                addTelemetryLog("Gravitasi dinormalisasi menjadi 1G standar.", "EARTH_GRAV");
                showToast("Generator mati. Kembali ke mode Bumi.");
            }
        });

        particleCountInput.addEventListener('input', (e) => {
            maxParticles = parseInt(e.target.value);
            particleCountVal.innerText = maxParticles;
            initParticles();
        });

        particleSpeedInput.addEventListener('input', (e) => {
            gravityForce = parseFloat(e.target.value) * 0.1;
            powerVal.innerText = e.target.value + " G";
        });

        resetBtn.addEventListener('click', () => {
            initParticles();
            antiGravitySwitch.checked = false;
            isAntiGravity = false;
            switchLabel.innerHTML = "GAYA TARIK BUMI";
            switchLabel.className = "text-danger ms-2";
            gravityForce = 0.5;
            particleSpeedInput.value = 5;
            powerVal.innerText = "5.0 G";
            addTelemetryLog("Seluruh simulator berhasil di-reset.", "RESET_DONE");
            showToast("Simulasi telah dikembalikan ke kondisi default.");
        });

        calibrateBtn.addEventListener('click', () => {
            showToast("Kalibrasi kuantum selesai. Stabilitas diatur ke 100%.");
            stabilityBar.style.width = "100%";
            addTelemetryLog("Kalibrasi sistem reaktor sukses penuh.", "CALIB_OK");
        });

        // Helper Functions for Toast & Logs
        function showToast(message) {
            const toastEl = document.getElementById('liveToast');
            document.getElementById('toastMessage').innerText = message;
            const toast = new bootstrap.Toast(toastEl);
            toast.show();
        }

        function triggerSuccessToast() {
            showToast(`Selamat ${document.getElementById('userName').value}! Anda berhasil terdaftar.`);
            document.getElementById('applyForm').reset();
        }

        function addTelemetryLog(message, badgeText) {
            const date = new Date();
            const timeStr = `[${date.toTimeString().split(' ')[0]}]`;
            
            const badgeClass = badgeText === "ANOMALY" ? "bg-warning text-dark" : "bg-secondary";
            
            const newLog = document.createElement('li');
            newLog.className = "list-group-item bg-dark bg-opacity-70 text-slate-300 d-flex justify-between align-items-center border-secondary text-sm";
            newLog.innerHTML = `
                <span>${timeStr} ${message}</span>
                <span class="badge ${badgeClass}">${badgeText}</span>
            `;
            
            telemetryLog.prepend(newLog);
            if (telemetryLog.children.length > 5) {
                telemetryLog.removeChild(telemetryLog.lastChild);
            }
        }
    </script>
</body>
